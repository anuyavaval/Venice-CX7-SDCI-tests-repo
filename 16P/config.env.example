# CX7 SDCI test config — copy to config.env and fill in your values.
# config.env is git-ignored; NEVER commit real credentials.

# ── SUT (Device Under Test) ──
CX7_SUT_HOST=10.230.104.91      # SUT mgmt IP
CX7_SUT_USER=amd
CX7_SUT_PW=REPLACE_ME           # SUT ssh password
CX7_SUT_NIC=eth2                # CX7 NIC under test

# ── LoadGen ──
CX7_LG_HOST=10.230.96.142       # LoadGen mgmt IP
CX7_LG_USER=amd
CX7_LG_PW=REPLACE_ME            # LoadGen ssh password
CX7_LG_NIC=enp1s0np0

# ── Data plane ──
CX7_SRV_DATA_IP=192.168.10.3    # LoadGen data IP (iperf3 server + SUT client target)
                                # SUT data IP is 192.168.10.2 (local to eth2)

# ── Test knobs ──
CX7_IPERF_CORE=5                # core running iperf3 client
CX7_IRQ_CORE=261                # SMT sibling of core 5 (sibling = core + 256 on CCD0)
CX7_BASE_PORT=5201

# ── 16P (multi-core) ──
CX7_BASE_CORE=1                 # first iperf core (16 procs -> cores 1..16, skip core 0)
CX7_NUM_CORES=16                # cores / iperf3 processes / combined queues
CX7_SIBLING_OFFSET=256          # SMT sibling = core + 256 (CCD0); siblings 257..272
